name: Deploy to Cloud Run

# Push to main → prod deploy. Manual workflow_dispatch also supported.
# Auth: Workload Identity Federation, no JSON keys. The OIDC binding is
# scoped to this repo only (see bootstrap-gcp.sh step 11).
#
# Placeholders to replace at scaffold time:
#   {{SERVICE_NAME}} — Cloud Run service name
#   {{REGION}}       — GCP region

on:
  push:
    branches: [main]
  workflow_dispatch:

concurrency:
  group: deploy-${{ github.ref }}
  cancel-in-progress: false

jobs:
  deploy:
    runs-on: ubuntu-latest
    # `environment:` auto-creates a GitHub Deployment record and pulls the
    # service URL into it once the steps below set `steps.url.outputs.url`.
    environment:
      name: production
      url: ${{ steps.url.outputs.url }}
    permissions:
      id-token: write   # required for WIF
      contents: read
    steps:
      - uses: actions/checkout@v4

      - id: auth
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ vars.GCP_WORKLOAD_IDENTITY_PROVIDER }}
          service_account: ${{ vars.GCP_DEPLOYER_SA }}

      - uses: google-github-actions/setup-gcloud@v2
        with:
          project_id: ${{ vars.GCP_PROJECT_ID }}

      - name: Deploy
        run: ./deploy.sh

      - name: Resolve service URL
        id: url
        run: |
          url=$(gcloud run services describe {{SERVICE_NAME}} \
            --region={{REGION}} \
            --format='value(status.url)')
          echo "url=$url" >> $GITHUB_OUTPUT
