{
  "posthog": {
    "type": "http",
    "url": "https://mcp.posthog.com/mcp"
  },
  "vercel": {
    "type": "http",
    "url": "https://mcp.vercel.com"
  },
  "stripe": {
    "type": "http",
    "url": "https://mcp.stripe.com/"
  },
  "jina": {
    "type": "http",
    "url": "https://mcp.jina.ai/v1",
    "headers": {
      "Authorization": "Bearer ${JINA_API_KEY}"
    }
  },
  "context7": {
    "type": "http",
    "url": "https://mcp.context7.com/mcp",
    "headers": {
      "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
    }
  },
  "duckdb": {
    "type": "stdio",
    "command": "uvx",
    "args": [
      "mcp-server-motherduck",
      "--db-path",
      ":memory:",
      "--read-write",
      "--allow-switch-databases"
    ],
    "env": {}
  },
  "Neon": {
    "type": "http",
    "url": "https://mcp.neon.tech/mcp",
    "headers": {
      "Authorization": "Bearer ${NEON_API_KEY}"
    }
  },
  "supabase": {
    "type": "http",
    "url": "https://mcp.supabase.com/mcp"
  },
  "adadvisor": {
    "type": "http",
    "url": "https://api.adadvisor.ai/mcp"
  },
  "trello": {
    "command": "bunx",
    "args": ["@delorenj/mcp-server-trello"],
    "env": {
      "TRELLO_API_KEY": "${TRELLO_API_KEY}",
      "TRELLO_TOKEN": "${TRELLO_TOKEN}"
    }
  },
  "google-ads-mcp": {
    "command": "pipx",
    "args": [
      "run",
      "--spec",
      "git+https://github.com/googleads/google-ads-mcp.git",
      "google-ads-mcp"
    ],
    "env": {
      "GOOGLE_APPLICATION_CREDENTIALS": "${ADS_GOOGLE_CREDENTIALS_PATH}",
      "GOOGLE_PROJECT_ID": "${ADS_GOOGLE_CLOUD_PROJECT_ID}",
      "GOOGLE_ADS_DEVELOPER_TOKEN": "${GOOGLE_DEVELOPER_TOKEN}",
      "GOOGLE_ADS_LOGIN_CUSTOMER_ID": "${GOOGLE_ADS_MANAGER_ACCOUNT_ID}"
    }
  }
}
