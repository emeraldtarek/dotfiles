-- Auto-loaded by the DuckDB CLI on startup.
-- Reads AWS creds from ~/.aws/credentials (long-lived IAM user keys).
-- No expiry, no refresh juggling — works for `duckdb --ui` indefinitely.

INSTALL httpfs;
INSTALL aws;
LOAD httpfs;
LOAD aws;

CREATE OR REPLACE SECRET aws_secret (
    TYPE s3,
    PROVIDER credential_chain,
    CHAIN 'config',
    PROFILE 'adadvisor-logs',
    REGION 'us-east-2'
);
